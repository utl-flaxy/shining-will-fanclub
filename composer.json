{
    "name": "shining-will/fanclub",
    "description": "Shining-Will Fanclub",
    "type": "project",
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.3",
        "intervention/image": "^3.11",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.10",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-permission": "^6.23",
        "stripe/stripe-php": "^18.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.3",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
     "laravel": {
      "dont-discover": [
       "filament/support"
      ]
     }
    }
}
